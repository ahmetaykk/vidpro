{
  "server": {
    "host": "127.0.0.1",
    "port": 8767,
    "debug": false
  },
  "security": {
    "allowed_origins": [
      "http://127.0.0.1:8767",
      "http://localhost:8767"
    ],
    "allowed_methods": ["GET", "POST", "PUT", "DELETE"],
    "max_concurrent_downloads": 3,
    "encrypt_cookies": true
  },
  "paths": {
    "downloads": "./downloads",
    "cookies_cache": "./cookies_cache",
    "temp_dir": null
  },
  "defaults": {
    "quality": "best",
    "format": "mp4",
    "subtitle_languages": ["tr", "en"],
    "subtitle_format": "best",
    "audio_quality": "192"
  },
  "features": {
    "auto_cleanup_temp": true,
    "encrypt_cookies": true,
    "show_thumbnails": true,
    "save_metadata": false
  }
}
